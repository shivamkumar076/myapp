# Stage 1: Build
FROM node:18 AS build

WORKDIR /app

# Copy only app files
COPY my-react-app/package*.json ./
RUN npm install

COPY my-react-app/ ./

RUN npm run build


# Stage 2: Serve with nginx
FROM nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]