# Stage 1: Build
FROM node:18 AS build
WORKDIR /app



COPY frontend/my-react-app/package*.json ./
RUN npm cache clean --force && npm install

COPY . .
RUN npm run build


# Stage 2: Serve with nginx
FROM nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html   

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]